# Django settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,your-ec2-domain.com

# Database settings
POSTGRES_DB=soynadia
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-password
DB_HOST=db
DB_PORT=5432
DB_EXTERNAL_PORT=5432

# Admin User (created automatically on first run)
ADMIN_EMAIL=admin@soynadia.com
ADMIN_PASSWORD=changeme123456
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=User

# Security settings (for production)
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# CSRF Trusted Origins (required for Cloudflare Tunnel)
# Format: https://your-domain.com,https://another-domain.com
# For Cloudflare Tunnel, use your Cloudflare domain
CSRF_TRUSTED_ORIGINS=https://your-domain.cloudflare.com

# 2Captcha API Key (required for voting place queries)
# Get your API key from: https://2captcha.com/?from=1234567
# This key is used to solve reCAPTCHA challenges when querying voting places
# Format: your-api-key-here
TWOCAPTCHA_API_KEY=your-2captcha-api-key-here

# Twilio Auth Token (required for WhatsApp webhook signature validation)
# Get your Auth Token from: https://console.twilio.com/
# This token is used to validate webhook requests from Twilio
# Format: your-twilio-auth-token-here
TWILIO_AUTH_TOKEN=your-twilio-auth-token-here

# Twilio Skip Signature Validation (optional, for debugging only)
# Set to true to skip signature validation temporarily (NOT recommended for production)
# Format: true or false
TWILIO_SKIP_SIGNATURE_VALIDATION=false

# Twilio Webhook URL (required when using Cloudflare Tunnel or proxy)
# Exact webhook URL as configured in Twilio Console (protocol, host, path, trailing slash)
# Example: https://app.deikore.com/webhooks/twilio/whatsapp/
# Must match Twilio Console exactly or signature validation will fail
TWILIO_WEBHOOK_URL=https://your-domain.com/webhooks/twilio/whatsapp/
